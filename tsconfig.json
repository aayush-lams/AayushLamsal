{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
      "baseUrl": ".",
      "paths": {
          "@api/*"        : ["src/pages/api/*"],
          "@components/*" : ["src/components/*"],
          "@layouts/*"    : ["src/layouts/*"],
          "@libs/*"       : ["src/libs/*"],
          "@styles/*"     : ["src/styles/*"],
          "@public/*"     : ["public/*"],
          "@data/*"       : ["src/data/*"],
          "@scripts/*"    : ["src/scripts/*"],

          "@tests/*"      : ["tests/*"],
          "@tests/argp/*" : ["tests/argument_parser/*"]
      },
      "strict": false,
      "noImplicitAny": false,
      "strictNullChecks": false,
      "skipLibCheck": true
  }
}
