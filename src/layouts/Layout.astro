---
import "@styles/global.css";
import "@styles/freqStyles.css";
import Navbar  from '@components/navbar/Navbar.astro';
import Cursor from "@components/cursor/Cursor.astro";
import Connect from "@components/connect/Connect.astro";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/logo.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:title" content="Aayush Lamsal" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://www.aayush-lamsal.vercel.app" />
		<meta property="og:image" content="https://aayush-lamsal.vercel.app/og_img.png" />
		<meta property="og:description" content="Aayush lamsal's portfolio website" />
		<title>Aayush Lamsal</title>
	</head>
	<body>
	    <!-- <div class="bgImg"/> -->
	    <Cursor />
		<Navbar />
		<slot />
		<Connect />
	</body>
</html>

<style>
	html {
	position: relative;
		margin: 0;
		padding: 0;
		max-width: 100vw;
		max-height: 100vh;
		display: flex;
		justify-content: center;
		align-items: center;
		/*cursor: none;*/
	}
	body {
        width: min(95vw, 1920px);
        height: min(100vh, 1080px);
        display: flex;
        justify-content: center;
        align-items: center;
        background-color: var(--secondary);
        /*outline: 2px solid var(--secondaryWhiteDim);*/
    }
    /*.bgImg{
        position: absolute;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-image: url("/writing.jpg");
        background-repeat: repeat;
        opacity: 0.3;
    }*/
    @media screen and (max-width: 1000px) {
      body {
          display: flex;
          flex-direction: column;
          justify-content: flex-start;
      }
    }
</style>
