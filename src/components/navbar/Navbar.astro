---
import Logo    from '@components/logo/Logo.astro';

const currentPath = Astro.url.pathname;

const items = [
  { name: "about", href: "/" },
  { name: "skills", href: "/skills" },
  { name: "projects", href: "/projects" },
  { name: "blogs", href: "/blog" },
  // { name: "contact", href: "/contact" },
];
---

<nav>
    <Logo />
    <div class="myName">
        Aayush Lamsal
    </div>
    <div class="navOption">
        <div class="navDropper">
            =
        </div>
        <ul>
            {items.map((item) => (
            <li class={currentPath == item.href ? "active" : ""}>
                <a href={item.href}>- {item.name}</a>
            </li>
            ))}
        </ul>
    </div>
</nav>

<style>
    nav {
        /*background-color: red;*/
        padding: 1rem;
        width: fit-content;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 2rem;
        outline: 2px solid var(--secondaryWhiteDim);
        background-color: var(--secondary);
    }
    .navDropper{
        display: none;
        width:  40px;
        height: 40px;
        background-color: var(--secondary);
        outline: 2px double grey;
    }
    .myName{
        font-family: var(--fancy_font);
        font-weight: bolder;
        font-style: normal;
        font-size: 2rem;
    }
    ul{
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        gap: 0.5rem;
        overflow: hidden;
    }
    ul li {
        white-space: nowrap;
        width: 100%;
    }
    ul li a{
        display: block;
        padding: 0.5rem 1rem;
        width: 100%;
        transition: 0.3s ease;
    }
    ul li:hover a{
        color: #BEBEBE;
        text-shadow: 0 0 3px #AAAAAA;
        outline: 1px solid var(--secondaryWhiteDim);
        background-color: var(--secondaryWhiteDim);
    }
    .active{
        color: #BEBEBE;
        text-shadow: 0 0 3px #AAAAAA;
        outline: 1px solid var(--secondaryWhiteDim);
    }
    @media screen and (max-width: 1000px) {
        nav {
            width: calc(100% - 2rem);
            display: flex;
            justify-content: space-between;
            flex-direction: row;
            position: relative;
        }
        nav ul {
            position: absolute;
            top: 1rem;
            right: 1rem;
            height: 0;
            /*display: flex;
            flex-direction: row;*/
            transition: 0.3s ease;
        }
        .navDropper{
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .navOption:hover .navDropper{
            color: #BEBEBE;
        }
        .navOption:hover ul{
            padding: 0.3rem;
            height: auto;
            background-color: var(--secondary);
            outline: 2px solid var(--secondaryWhiteDim);
        }
    }
</style>
